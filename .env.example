# Copia este archivo a .env.local y completa los valores.
# Los encuentras en tu proyecto de Supabase: Project Settings > API.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Necesaria para el autocompletado de direcciones y el mapa interactivo
# de la Etapa 4 (Google Maps Platform: Places API + Maps JavaScript API).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key
